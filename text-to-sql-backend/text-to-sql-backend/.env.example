# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Model Priority (comma-separated, first available is used)
# Options: deepseek-r1:1.5b, sqlcoder:latest, llama3.2:3b
MODEL_PRIORITY=deepseek-r1:1.5b,sqlcoder:latest,llama3.2:3b

# Self-correction retries (when generated SQL fails execution)
MAX_CORRECTION_RETRIES=2

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
